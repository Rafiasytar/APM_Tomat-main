<!-- ====================================================================
     pages/history.ejs — Halaman Riwayat Prediksi
     EJS locals: historyList (array), title, activePage
     ==================================================================== -->

<%- include('../layout/main_top') %>

<div class="max-w-6xl mx-auto px-6 py-10">

  <% if (typeof isAuthenticated !== 'undefined' && !isAuthenticated) { %>
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="w-full max-w-xl text-center bg-white border border-[#E8E6E0] rounded-2xl px-6 py-12 shadow-sm">
      <div class="w-20 h-20 rounded-2xl bg-[#FEF0EF] border border-[#FCDAD7] flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#C0392B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V7.5a4.5 4.5 0 10-9 0v3m-.75 0h10.5A1.75 1.75 0 0119 12.25v6A1.75 1.75 0 0117.25 20H6.75A1.75 1.75 0 015 18.25v-6a1.75 1.75 0 011.75-1.75z" />
        </svg>
      </div>
      <h1 class="font-heading font-extrabold text-2xl md:text-3xl text-[#1C1A16] mb-3">Akses Terbatas</h1>
      <p class="text-[#7A7870] font-light leading-relaxed mb-7">
        Masukkan akun terlebih dahulu untuk melihat riwayat prediksi. Hasil scan hanya akan tersimpan setelah Anda masuk ke akun.
      </p>
      <a href="/login"
         class="inline-flex items-center justify-center gap-2 bg-[#C0392B] hover:bg-[#922B21] text-white
                font-heading font-semibold px-7 py-3 rounded-xl transition-all duration-200 no-underline">
        Masuk
      </a>
      <p class="text-sm text-[#7A7870] mt-5">
        Belum punya akun?
        <a href="/register" class="font-heading font-bold text-[#C0392B] hover:underline no-underline">Daftar Sekarang</a>
      </p>
    </div>
  </div>
  <% } else { %>

  <!-- Header riwayat -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="font-heading font-extrabold text-2xl md:text-3xl text-[#1C1A16]">Riwayat Prediksi</h1>
      <p class="text-[#7A7870] font-light mt-1">
        <span class="font-semibold text-[#1C1A16]"><%= historyList.length %></span> hasil tersimpan
      </p>
    </div>
  </div>

  <% if (historyList.length === 0) { %>
  <!-- ── EMPTY STATE ────────────────────────────────────────────────────── -->
  <div class="text-center py-24 text-[#7A7870]">
    <div class="w-20 h-20 rounded-2xl bg-[#FAFAF8] border border-[#E8E6E0] flex items-center
                justify-center mx-auto mb-5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 text-[#E8E6E0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
    </div>
    <h3 class="font-heading font-bold text-lg text-[#1C1A16] mb-1">Belum Ada Riwayat</h3>
    <p class="text-sm font-light mb-6">Hasil prediksi akan tersimpan otomatis di sini setelah scan.</p>
    <a href="/predict"
       class="inline-flex items-center gap-2 bg-[#C0392B] hover:bg-[#922B21] text-white
              font-heading font-semibold px-6 py-3 rounded-xl transition-all duration-200 no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Mulai Prediksi Pertama
    </a>
  </div>

  <% } else { %>
  <!-- ── FILTER CHIPS & BATCH ACTIONS ───────────────────────────────────── -->
  <%
    const diseaseFilters = [];
    const diseaseFilterKeys = new Set();
    function diseaseFilterKey(entry) {
      const value = entry && entry.disease ? (entry.disease.en || entry.disease.name) : 'unknown';
      return String(value || 'unknown').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'unknown';
    }
    historyList.forEach(entry => {
      const key = diseaseFilterKey(entry);
      if (!diseaseFilterKeys.has(key)) {
        diseaseFilterKeys.add(key);
        diseaseFilters.push({
          key,
          label: entry && entry.disease ? (entry.disease.name || entry.disease.en || 'Tidak diketahui') : 'Tidak diketahui'
        });
      }
    });
  %>
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6 bg-white border border-[#E8E6E0] rounded-2xl px-4 py-3">
    
    <!-- Kiri: Filter penyakit -->
    <div class="flex items-center gap-3">
      <label for="diseaseFilter" class="text-sm font-heading font-bold text-[#1C1A16]">Jenis Penyakit</label>
      <select id="diseaseFilter"
              onchange="filterCards(this.value)"
              class="min-w-[240px] max-w-full bg-white border border-[#E8E6E0] text-[#1C1A16]
                     text-sm px-4 py-2 rounded-xl font-medium outline-none transition-all cursor-pointer
                     focus:border-[#C0392B] focus:ring-2 focus:ring-[#FCDAD7]">
        <option value="semua">Semua</option>
        <% diseaseFilters.forEach(filter => { %>
        <option value="<%= filter.key %>"><%= filter.label %></option>
        <% }) %>
      </select>
    </div>

    <!-- Kanan: Batch Actions -->
    <div class="flex items-center gap-4">
      <label class="flex items-center gap-2 text-sm text-[#1C1A16] font-medium cursor-pointer select-none">
        <input type="checkbox" id="selectAllCheckbox" class="w-4 h-4 rounded border-gray-300 text-[#C0392B] focus:ring-[#C0392B]" onchange="toggleSelectAll(this)">
        Pilih Semua
      </label>
      <span class="text-sm font-semibold text-[#C0392B]" id="selectedCount">0 data</span>
      <form action="/history/batch-delete" method="POST" id="batchDeleteForm" onsubmit="return confirm('Hapus riwayat yang dipilih?')">
        <input type="hidden" name="ids" id="selectedIdsInput" value="">
        <button type="submit" id="btnBatchDelete" disabled
                class="flex items-center gap-2 bg-[#F5F5F5] text-[#A09E96] px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed
                       hover:bg-[#EAEAEA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Hapus Pilihan
        </button>
      </form>
    </div>
  </div>

  <!-- ── GRID KARTU RIWAYAT ─────────────────────────────────────────────── -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="history-grid">

    <% historyList.forEach(function(entry) { %>
    <div class="history-card bg-white border border-[#E8E6E0] rounded-2xl overflow-hidden
                hover:-translate-y-1 hover:shadow-lg transition-all duration-200 group relative cursor-pointer"
         data-disease="<%= diseaseFilterKey(entry) %>"
         onclick="openDetailModal('<%= entry.id %>')">

      <!-- Thumbnail -->
      <% if (entry.imgPath) { %>
      <img src="<%= entry.imgPath %>" alt="<%= entry.disease.name %>"
           class="w-full h-36 object-cover bg-[#FAFAF8]">
      <% } else { %>
      <div class="w-full h-36 bg-gradient-to-br from-[#FEF0EF] to-[#FAFAF8] flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-12 h-12 opacity-25">
          <path d="M12 4 C12 4, 10 2, 8 3" stroke="#C0392B" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M12 4 V7" stroke="#4CAF50" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="12" cy="14" r="7" fill="#C0392B"/>
          <circle cx="10" cy="12" r="2.5" fill="white" opacity="0.5"/>
        </svg>
      </div>
      <% } %>

      <!-- Checkbox hidden until hovered or selected -->
      <div class="absolute top-2 left-2 z-10" onclick="event.stopPropagation()">
        <input type="checkbox" class="card-checkbox w-5 h-5 rounded border-gray-300 text-[#C0392B] focus:ring-[#C0392B] shadow-sm bg-white cursor-pointer" value="<%= entry.id %>" onchange="updateBatchSelection()">
      </div>

      <!-- Body kartu -->
      <div class="p-4 bg-white flex flex-col h-[110px]">
        <h3 class="font-heading font-bold text-[15px] text-[#1C1A16] leading-tight mb-1 line-clamp-1">
          <%= entry.disease.name %>
        </h3>
        <p class="text-[11px] text-[#A09E96] font-medium mb-auto"><%= entry.date %></p>
        
        <div class="border-t border-[#F0F0F0] pt-3 mt-2 flex justify-between items-center">
          <span class="text-[11px] text-[#7A7870] font-medium">Akurasi Model</span>
          <span class="text-xs font-bold text-[#2D7A3A]"><%= entry.accuracy %>%</span>
        </div>
      </div>
    </div>
    <% }); %>

  </div>

  <!-- Script filter & batch delete client-side -->
  <script>
    // Modal Logic
    function openDetailModal(id) {
      const modal = document.getElementById('modal-' + id);
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden'; // disable scrolling
      }
    }

    function closeDetailModal(id) {
      const modal = document.getElementById('modal-' + id);
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = ''; // re-enable scrolling
      }
    }

    // Filter kartu berdasarkan jenis penyakit
    function filterCards(disease) {
      document.querySelectorAll('.history-card').forEach(card => {
        card.style.display = (disease === 'semua' || card.dataset.disease === disease) ? '' : 'none';
      });
      updateBatchSelection(); // Reset selection on filter
    }

    // Batch Selection Logic
    function updateBatchSelection() {
      const checkboxes = document.querySelectorAll('.card-checkbox:checked');
      const count = checkboxes.length;
      document.getElementById('selectedCount').innerText = count + ' data';
      
      const btnDelete = document.getElementById('btnBatchDelete');
      if (count > 0) {
        btnDelete.disabled = false;
        btnDelete.classList.remove('bg-[#F5F5F5]', 'text-[#A09E96]');
        btnDelete.classList.add('bg-red-50', 'text-[#C0392B]', 'border', 'border-red-200', 'hover:bg-red-100');
      } else {
        btnDelete.disabled = true;
        btnDelete.classList.add('bg-[#F5F5F5]', 'text-[#A09E96]');
        btnDelete.classList.remove('bg-red-50', 'text-[#C0392B]', 'border', 'border-red-200', 'hover:bg-red-100');
      }

      // Update hidden input
      const ids = Array.from(checkboxes).map(cb => cb.value).join(',');
      document.getElementById('selectedIdsInput').value = ids;

      // Update Select All checkbox state
      const visibleCheckboxes = Array.from(document.querySelectorAll('.card-checkbox')).filter(cb => cb.closest('.history-card').style.display !== 'none');
      const selectAllCb = document.getElementById('selectAllCheckbox');
      selectAllCb.checked = (visibleCheckboxes.length > 0 && Array.from(visibleCheckboxes).every(cb => cb.checked));
    }

    function toggleSelectAll(selectAllCheckbox) {
      const isChecked = selectAllCheckbox.checked;
      document.querySelectorAll('.card-checkbox').forEach(cb => {
        const card = cb.closest('.history-card');
        if (card.style.display !== 'none') {
          cb.checked = isChecked;
        }
      });
      updateBatchSelection();
    }
  </script>

  <!-- MODALS CONTAINER -->
  <% historyList.forEach(function(entry) { %>
  <div id="modal-<%= entry.id %>" class="fixed inset-0 z-[999] hidden items-center justify-center p-4 sm:p-6 bg-[#1C1A16]/60 backdrop-blur-sm" onclick="closeDetailModal('<%= entry.id %>')">
    <div class="bg-white rounded-3xl w-full max-w-2xl max-h-[90vh] overflow-y-auto shadow-2xl relative animate-fade-up flex flex-col" onclick="event.stopPropagation()">
      <!-- Close button -->
      <button onclick="closeDetailModal('<%= entry.id %>')" class="absolute top-4 right-4 z-20 bg-white/90 hover:bg-white hover:scale-105 active:scale-95 text-[#1C1A16] rounded-full p-2.5 shadow-lg backdrop-blur-md transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <!-- Gambar di atas -->
      <div class="p-6 sm:p-8 flex-1">
        <!-- Header -->
        <div class="flex items-start justify-between mb-5">
          <div>
            <h1 class="font-heading font-extrabold text-2xl text-[#C0392B] leading-tight"><%= entry.disease.name %></h1>
            <p class="text-sm text-[#7A7870] italic mt-1"><%= entry.disease.en %></p>
          </div>
          <span class="bg-[#E8F5EA] text-[#2D7A3A] text-sm font-heading font-bold px-3 py-1.5 rounded-full flex-shrink-0 ml-4 border border-[#C8E6CC] shadow-sm"><%= entry.accuracy %>%</span>
        </div>

        <!-- Gambar yang diupload (sesuai halaman prediksi) -->
        <% if (entry.imgPath) { %>
        <img src="<%= entry.imgPath %>" alt="Gambar yang dianalisis"
             class="w-full rounded-xl object-cover max-h-48 mb-5 border border-[#E8E6E0]">
        <% } %>

        <!-- Tanggal scan -->
        <p class="text-xs text-[#7A7870] font-medium mb-6 flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#C0392B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg> 
          Discan pada <%= entry.date %>
        </p>

        <!-- Badge severity -->
        <div class="flex items-center gap-3 rounded-2xl px-5 py-4 mb-6 text-sm font-bold border <%= entry.severity === 'tinggi' ? 'bg-[#FEF0EF] text-[#C0392B] border-[#FCDAD7]' : entry.severity === 'sedang' ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-[#E8F5EA] text-[#2D7A3A] border-[#C8E6CC]' %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <%= entry.severityLabel %>
        </div>

        <!-- Metrics -->
        <div class="mb-6">
          <p class="text-[11px] font-heading font-bold uppercase tracking-widest text-[#A09E96] mb-3">Metrik Evaluasi Model</p>
          <div class="grid grid-cols-4 gap-3">
            <div class="bg-white border border-[#E8E6E0] shadow-sm rounded-2xl p-3 text-center flex flex-col justify-center"><div class="font-heading font-extrabold text-lg text-[#1C1A16]"><%= entry.accuracy %>%</div><div class="text-[10px] uppercase font-bold tracking-wide text-[#7A7870] mt-1">Accuracy</div></div>
            <div class="bg-white border border-[#E8E6E0] shadow-sm rounded-2xl p-3 text-center flex flex-col justify-center"><div class="font-heading font-extrabold text-lg text-[#1C1A16]"><%= entry.metrics.precision || '-' %>%</div><div class="text-[10px] uppercase font-bold tracking-wide text-[#7A7870] mt-1">Precision</div></div>
            <div class="bg-white border border-[#E8E6E0] shadow-sm rounded-2xl p-3 text-center flex flex-col justify-center"><div class="font-heading font-extrabold text-lg text-[#1C1A16]"><%= entry.metrics.recall || '-' %>%</div><div class="text-[10px] uppercase font-bold tracking-wide text-[#7A7870] mt-1">Recall</div></div>
            <div class="bg-white border border-[#E8E6E0] shadow-sm rounded-2xl p-3 text-center flex flex-col justify-center"><div class="font-heading font-extrabold text-lg text-[#1C1A16]"><%= entry.metrics.f1 || '-' %>%</div><div class="text-[10px] uppercase font-bold tracking-wide text-[#7A7870] mt-1">F1-Score</div></div>
          </div>
        </div>

        <!-- Gejala Umum -->
        <div class="mb-6">
          <p class="text-[11px] font-heading font-bold uppercase tracking-widest text-[#A09E96] mb-3">Gejala Umum</p>
          <div class="flex flex-wrap gap-2">
            <% (entry.symptoms || []).forEach(symptom => { %>
            <span class="inline-flex items-center bg-[#FAFAF8] border border-[#E8E6E0] rounded-full text-xs font-medium px-4 py-1.5 text-[#1C1A16] shadow-sm"><%= symptom %></span>
            <% }) %>
          </div>
        </div>

        <!-- Saran Pengobatan -->
        <div class="mb-8">
          <p class="text-[11px] font-heading font-bold uppercase tracking-widest text-[#A09E96] mb-3">Saran Pengobatan</p>
          <div class="space-y-4">
            <% (entry.treatments || []).forEach(treatment => { %>
            <div class="border-l-[5px] rounded-r-2xl p-4 sm:p-5 bg-white shadow-sm border border-[#E8E6E0] border-l-transparent <%= treatment.type === 'green' ? '!border-l-[#4CAF50]' : treatment.type === 'amber' ? '!border-l-amber-500' : '!border-l-[#C0392B]' %>">
              <h4 class="font-heading font-bold text-sm text-[#1C1A16] mb-1.5"><%= treatment.title %></h4>
              <p class="text-sm text-[#7A7870] font-normal leading-relaxed"><%= treatment.text %></p>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Aksi -->
        <div class="flex gap-3 pt-5 border-t border-[#E8E6E0]">
          <form action="/history/delete/<%= entry.id %>" method="POST" onsubmit="return confirm('Hapus riwayat ini?')" class="w-full">
            <button type="submit" class="w-full flex items-center justify-center gap-2 bg-[#FAFAF8] border border-[#E8E6E0] text-[#C0392B] hover:bg-[#FEF0EF] hover:border-[#FCDAD7] font-heading font-bold text-sm px-6 py-3.5 rounded-2xl transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg> Hapus Riwayat Ini
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
  <% }); %>

  <% } %>

  <% } %>
</div>

<%- include('../layout/main_bottom') %>
