<!-- ====================================================================
     pages/detail.ejs — Halaman Detail Hasil Prediksi
     Data dari EJS locals: entry (objek riwayat tunggal)
     ==================================================================== -->

<%- include('../layout/main_top') %>
<div class="max-w-2xl mx-auto px-6 py-10">

  <!-- Tombol kembali -->
  <a href="/history"
     class="inline-flex items-center gap-2 text-[#7A7870] hover:text-[#C0392B]
            transition-colors mb-6 no-underline group">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    <span class="text-sm font-medium">Kembali ke Riwayat</span>
  </a>

  <!-- Kartu detail -->
  <div class="bg-white border border-[#E8E6E0] rounded-2xl overflow-hidden">

    <!-- Gambar di atas -->
    <% if (entry.imgPath) { %>
    <img src="<%= entry.imgPath %>" alt="<%= entry.disease.name %>"
         class="w-full object-cover max-h-64 bg-[#FAFAF8]">
    <% } else { %>
    <div class="w-full h-48 bg-gradient-to-br from-[#FEF0EF] to-[#FAFAF8] flex items-center justify-center">
      <svg viewBox="0 0 24 24" fill="none" class="w-16 h-16 opacity-20">
        <path d="M12 4 C12 4, 10 2, 8 3" stroke="#C0392B" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M12 4 V7" stroke="#4CAF50" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="12" cy="14" r="7" fill="#C0392B"/>
        <circle cx="10" cy="12" r="2.5" fill="white" opacity="0.5"/>
      </svg>
    </div>
    <% } %>

    <div class="p-6">

      <!-- Header -->
      <div class="flex items-start justify-between mb-1">
        <div>
          <h1 class="font-heading font-extrabold text-xl text-[#C0392B]"><%= entry.disease.name %></h1>
          <p class="text-sm text-[#7A7870] italic"><%= entry.disease.en %></p>
        </div>
        <span class="bg-[#E8F5EA] text-[#2D7A3A] text-sm font-heading font-semibold px-3 py-1 rounded-full flex-shrink-0 ml-4">
          <%= entry.accuracy %>%
        </span>
      </div>

      <!-- Tanggal scan -->
      <p class="text-xs text-[#7A7870] mt-2 mb-5 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Discan pada <%= entry.date %>
      </p>

      <!-- Badge severity -->
      <div class="flex items-center gap-2 rounded-xl px-4 py-3 mb-5 text-sm font-medium
                  <%= entry.severity === 'tinggi' ? 'bg-red-50 text-red-700' :
                      entry.severity === 'sedang' ? 'bg-amber-50 text-amber-700' :
                      'bg-[#E8F5EA] text-[#2D7A3A]' %>">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <%= entry.severityLabel %>
      </div>

      <!-- Accuracy bar -->
      <div class="mb-5">
        <div class="flex justify-between text-xs text-[#7A7870] mb-1.5">
          <span>Akurasi Model</span>
          <span class="font-semibold text-[#1C1A16]"><%= entry.accuracy %>%</span>
        </div>
        <div class="h-2 bg-[#E8E6E0] rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-[#C0392B] to-[#E06050] rounded-full acc-bar-fill"
               style="width: 0%"
               data-width="<%= entry.accuracy %>%">
          </div>
        </div>
      </div>

      <!-- Metrics -->
      <div class="mb-5">
        <p class="text-xs font-heading font-bold uppercase tracking-widest text-[#7A7870] mb-3">
          Metrik Evaluasi Model
        </p>
        <div class="grid grid-cols-4 gap-2">
          <div class="bg-[#FAFAF8] border border-[#E8E6E0] rounded-xl p-3 text-center">
            <div class="font-heading font-bold text-base text-[#1C1A16]"><%= entry.accuracy %>%</div>
            <div class="text-xs text-[#7A7870] mt-0.5">Accuracy</div>
          </div>
          <div class="bg-[#FAFAF8] border border-[#E8E6E0] rounded-xl p-3 text-center">
            <div class="font-heading font-bold text-base text-[#1C1A16]"><%= entry.metrics.precision %>%</div>
            <div class="text-xs text-[#7A7870] mt-0.5">Precision</div>
          </div>
          <div class="bg-[#FAFAF8] border border-[#E8E6E0] rounded-xl p-3 text-center">
            <div class="font-heading font-bold text-base text-[#1C1A16]"><%= entry.metrics.recall %>%</div>
            <div class="text-xs text-[#7A7870] mt-0.5">Recall</div>
          </div>
          <div class="bg-[#FAFAF8] border border-[#E8E6E0] rounded-xl p-3 text-center">
            <div class="font-heading font-bold text-base text-[#1C1A16]"><%= entry.metrics.f1 %>%</div>
            <div class="text-xs text-[#7A7870] mt-0.5">F1-Score</div>
          </div>
        </div>
      </div>

      <!-- Gejala Umum -->
      <div class="mb-5">
        <p class="text-xs font-heading font-bold uppercase tracking-widest text-[#7A7870] mb-3">Gejala Umum</p>
        <div class="flex flex-wrap gap-2">
          <% entry.symptoms.forEach(symptom => { %>
          <span class="inline-flex items-center bg-[#FAFAF8] border border-[#E8E6E0] rounded-full
                       text-sm px-3 py-1 text-[#1C1A16]">
            <%= symptom %>
          </span>
          <% }) %>
        </div>
      </div>

      <!-- Saran Pengobatan -->
      <div class="mb-6">
        <p class="text-xs font-heading font-bold uppercase tracking-widest text-[#7A7870] mb-3">Saran Pengobatan</p>
        <div class="space-y-3">
          <% entry.treatments.forEach(treatment => { %>
          <div class="border-l-4 rounded-r-xl p-4 bg-[#FAFAF8]
                      <%= treatment.type === 'green' ? 'border-l-[#2D7A3A]' :
                          treatment.type === 'amber' ? 'border-l-amber-500' :
                          'border-l-[#C0392B]' %>">
            <h4 class="font-heading font-semibold text-sm text-[#1C1A16] mb-1"><%= treatment.title %></h4>
            <p class="text-sm text-[#7A7870] font-light leading-relaxed"><%= treatment.text %></p>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Aksi: Hapus & Scan Ulang -->
      <div class="flex gap-3 pt-5 border-t border-[#E8E6E0]">
        <a href="/predict"
           class="flex-1 flex items-center justify-center gap-2 bg-[#C0392B] hover:bg-[#922B21]
                  text-white font-heading font-semibold text-sm py-3 rounded-xl
                  transition-all duration-200 no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Prediksi Baru
        </a>
        <form action="/history/delete/<%= entry.id %>" method="POST"
              onsubmit="return confirm('Hapus riwayat ini?')">
          <button type="submit"
                  class="flex items-center justify-center gap-2 border border-red-200 text-[#C0392B]
                         hover:bg-red-50 font-heading font-semibold text-sm px-4 py-3 rounded-xl
                         transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Hapus
          </button>
        </form>
      </div>

    </div>
  </div>
</div><%- include('../layout/main_bottom') %>
