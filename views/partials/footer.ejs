<!-- ====================================================================
     partials/footer.ejs — Footer Aplikasi TomatoScan
     ==================================================================== -->

<footer class="bg-[#1C1A16] text-white mt-20">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Kolom 1: Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#C0392B] flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5">
              <path d="M12 4 C12 4, 10 2, 8 3" stroke="#4CAF50" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M12 4 C12 4, 14 2, 16 3" stroke="#4CAF50" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M12 4 V7" stroke="#4CAF50" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="12" cy="14" r="7" fill="rgba(255,255,255,0.9)"/>
              <circle cx="10" cy="12" r="2.5" fill="rgba(255,255,255,0.4)"/>
            </svg>
          </div>
          <span class="font-heading font-extrabold text-xl">Tomato<span class="text-[#E06050]">Scan</span></span>
        </div>
        <p class="text-sm text-white/50 leading-relaxed font-light">
          Deteksi penyakit tanaman tomat secara akurat dan instan menggunakan teknologi kecerdasan buatan.
        </p>
      </div>

      <!-- Kolom 2: Navigasi -->
      <div>
        <h4 class="font-heading font-semibold text-sm text-white/70 uppercase tracking-widest mb-4">Navigasi</h4>
        <ul class="space-y-2 list-none p-0 m-0">
          <li><a href="/" class="text-sm text-white/50 hover:text-[#E06050] transition-colors no-underline">Beranda</a></li>
          <li><a href="/predict" class="text-sm text-white/50 hover:text-[#E06050] transition-colors no-underline">Prediksi Penyakit</a></li>
          <li><a href="/history" class="text-sm text-white/50 hover:text-[#E06050] transition-colors no-underline">Riwayat Prediksi</a></li>
        </ul>
      </div>

      <!-- Kolom 3: Info -->
      <div>
        <h4 class="font-heading font-semibold text-sm text-white/70 uppercase tracking-widest mb-4">Teknologi</h4>
        <ul class="space-y-2 list-none p-0 m-0">
          <li class="flex items-center gap-2 text-sm text-white/50">
            <span class="w-1.5 h-1.5 rounded-full bg-[#2D7A3A]"></span>
            MobileNetV2 Deep Learning
          </li>
          <li class="flex items-center gap-2 text-sm text-white/50">
            <span class="w-1.5 h-1.5 rounded-full bg-[#C0392B]"></span>
            Express.js + EJS
          </li>
          <li class="flex items-center gap-2 text-sm text-white/50">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            Tailwind CSS
          </li>
        </ul>
      </div>
    </div>

    <!-- Garis pemisah & copyright -->
    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/30">
        &copy; <%= new Date().getFullYear() %> TomatoScan. Dibuat untuk keperluan akademik.
      </p>
      <p class="text-xs text-white/30">
        Teknologi AI untuk petani Indonesia 🇮🇩
      </p>
    </div>
  </div>
</footer>
